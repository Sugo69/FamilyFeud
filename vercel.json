{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "functions": {
    "api/lesson-pipeline.js": { "maxDuration": 300 },
    "api/generate.js": { "maxDuration": 60 },
    "api/generate-questions.js": { "maxDuration": 30 },
    "api/fetch-content.js": { "maxDuration": 10 }
  }
}
